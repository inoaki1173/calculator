{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.vue",
    "src/preload/*.d.ts"
, "tests/setup.ts", "tests/utils.ts", "tests/basic-tests/VuetifyComponent.spec.ts"  ],
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@renderer/*": [
        "./src/renderer/src/*"
      ],
      "@tests/*": [
        "./tests/*"
      ]
    }
  }
}
